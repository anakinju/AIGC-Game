[tool.poetry]
name = "aigc-game"
version = "0.1.0"
description = "An innovative game project leveraging AI agents for dynamic narrative and player interactions"
authors = ["Your Team"]
readme = "README.md"
packages = [{include = "aigc_game"}]

[tool.poetry.dependencies]
python = "^3.9"
# 原有依赖
openai = "^1.12.0"  # For LLM interactions
pydantic = "^2.6.0"  # For data validation
fastapi = "^0.109.0"  # For API interfaces
sqlalchemy = "^2.0.27"  # For database operations
python-dotenv = "^1.0.0"  # For environment management
langchain = "^0.3.18"  # For LLM chain operations
numpy = "^1.26.0"  # For numerical operations
pytest = "^8.0.0"  # For testing
openevals = "^0.1.0"
langgraph = "^0.4.8"
langchain-openai = "^0.3.24"
sentence-transformers = "^4.1.0"
asyncio = "^3.4.3"
requests = "^2.32.4"

# 从narrative添加的依赖
pyvis = "^0.3.2"  # For network visualization
networkx = "^2.5"  # For network analysis
matplotlib = "^3.3.4"  # For plotting
jupyter = "^1.0.0"  # For Jupyter notebooks
ipython = "^7.20.0"  # For interactive Python
tqdm = "^4.56.0"  # For progress bars
torch = "^2.7.1"  # For PyTorch (AI/ML)

[tool.poetry.group.dev.dependencies]
black = "^24.1.0"
isort = "^5.13.0"
flake8 = "^7.0.0"
mypy = "^1.8.0"
pytest-cov = "^4.1.0"
sphinx = "^7.2.0"
sphinx-rtd-theme = "^2.0.0"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"

[tool.black]
line-length = 88
target-version = ['py39']
include = '\.pyi?$'

[tool.isort]
profile = "black"
multi_line_output = 3

[tool.mypy]
python_version = "3.9"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = true